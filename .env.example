# Supabase — vai a Settings > Database > Connection string
# Escolhe "URI" mode para DATABASE_URL (pooling)
# Escolhe "URI" mode com "Session mode" para DIRECT_URL
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[ref]:[password]@aws-0-eu-west-1.pooler.supabase.com:5432/postgres"

# Supabase — vai a Settings > API
SUPABASE_URL="https://xxxx.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# Servidor
PORT=3001

# Frontend URL (para o CORS)
FRONTEND_URL="http://localhost:3000"

# JWT secret — igual ao que está no Supabase (Settings > API > JWT Secret)
JWT_SECRET="your-jwt-secret"
